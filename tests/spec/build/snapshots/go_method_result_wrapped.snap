// === main.go ===
package main

import (
	"bufio"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strings"
)

func main() {
	reader := bufio.NewReader(strings.NewReader("hello\nworld"))
	ret_1, ret_2 := reader.ReadByte()
	var b lisette.Result[byte, error]
	if ret_2 != nil {
		b = lisette.MakeResultErr[byte, error](ret_2)
	} else {
		b = lisette.MakeResultOk[byte, error](ret_1)
	}
	if b.Tag == lisette.ResultOk {
		fmt.Print(b.OkVal)
	} else {
		fmt.Print("error")
	}
}
