---
source: tests/spec/emit/patterns.rs
description: "input: \nfn test(opt: Option<int>) -> int {\n  let x = 1;\n  let x = match opt {\n    Some(v) => v,\n    None => 0,\n  };\n  x\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(opt lisette.Option[int]) int {
	var x int
	if opt.Tag == lisette.OptionSome {
		v := opt.SomeVal
		x = v
	} else {
		x = 0
	}
	return x
}
